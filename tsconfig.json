		"imageStyles.ts",
		"ImageStylePanel.ts",
		"imageAura.ts",
		"vibeTilt.ts",
		"vibeSparkles.ts",
		"styleClipboard.ts",
		"canvasChrome.ts",
		"CanvasStylePanel.ts"
	]
}
